# Runs at install time (after every `flutter build windows` / IDE build).
# Mirrors the installed runner bundle to windows_dist/<Config>.
# Do not use CMAKE_INSTALL_PREFIX here: Flutter's cmake_install.cmake sets it to
# $<TARGET_FILE_DIR:...>, which is not expanded when cmake runs the install script.

set(PRIVATE_AI_AGENT_DEPLOY_ROOT "@PRIVATE_AI_AGENT_DEPLOY_ROOT@")
set(PRIVATE_AI_AGENT_DEFAULT_CFG "@PRIVATE_AI_AGENT_DEFAULT_BUILD_TYPE@")

if(CMAKE_INSTALL_CONFIG_NAME)
  set(_cfg "${CMAKE_INSTALL_CONFIG_NAME}")
elseif(PRIVATE_AI_AGENT_DEFAULT_CFG)
  set(_cfg "${PRIVATE_AI_AGENT_DEFAULT_CFG}")
else()
  set(_cfg "Release")
endif()

get_filename_component(_src "${CMAKE_CURRENT_LIST_DIR}/runner/${_cfg}" ABSOLUTE)
set(_dest "${PRIVATE_AI_AGENT_DEPLOY_ROOT}/${_cfg}")

message(STATUS "Private AI Agent: mirroring Windows bundle ${_src} -> ${_dest}")

if(EXISTS "${_dest}")
  file(REMOVE_RECURSE "${_dest}")
endif()

execute_process(
  COMMAND "${CMAKE_COMMAND}" -E copy_directory "${_src}" "${_dest}"
  RESULT_VARIABLE _private_ai_agent_copy_rc)
if(NOT _private_ai_agent_copy_rc EQUAL 0)
  message(FATAL_ERROR "Private AI Agent: copy to windows_dist failed (code ${_private_ai_agent_copy_rc})")
endif()
